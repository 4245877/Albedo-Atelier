{
  "name": "@atelier/print-orchestrator",
  "version": "0.1.0",
  "private": true,
  "description": "Fastify service for orchestrating FDM and resin 3D printers.",
  "main": "dist/src/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "NODE_OPTIONS=\"--experimental-sqlite --disable-warning=ExperimentalWarning\" tsx watch src/server.ts",
    "start": "node --experimental-sqlite --disable-warning=ExperimentalWarning dist/src/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "slicing:vendor:check": "node scripts/install-orca-vendor-profiles.mjs --check",
    "slicing:vendor:install": "node scripts/install-orca-vendor-profiles.mjs",
    "test": "TZ=UTC node --experimental-sqlite --disable-warning=ExperimentalWarning --import tsx --test \"src/**/*.test.ts\"",
    "test:unit": "node scripts/select-tests.mjs unit | TZ=UTC xargs node --experimental-sqlite --disable-warning=ExperimentalWarning --import tsx --test",
    "test:integration": "node scripts/select-tests.mjs integration | TZ=UTC xargs node --experimental-sqlite --disable-warning=ExperimentalWarning --import tsx --test",
    "lint:complexity": "node scripts/check-complexity.mjs"
  },
  "dependencies": {
    "@fastify/multipart": "^9.0.3",
    "fast-xml-parser": "^5.10.1",
    "fastify": "^5.4.0",
    "mqtt": "^5.10.1",
    "suncalc": "1.9.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/suncalc": "1.9.2",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.1"
}
