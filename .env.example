# Secrets for real printers referenced from
# apps/print-orchestrator/config/printers.json via ${VAR} placeholders.
# Copy to .env (gitignored) and fill in the real values.

# Bambu Lab A1 Combo — LAN mode credentials (printer screen → settings → LAN).
BAMBU_A1_SERIAL=
BAMBU_A1_ACCESS_CODE=

# Security (recommended):
# Shared secret required on state-changing requests (pause/resume/cancel/light/
# snapshot/print/queue) and on the one side-effectful read
# (camera.jpg?ensureLight=1). Other reads stay open. Unset = control actions are
# refused (503) unless ALLOW_UNAUTHENTICATED_MUTATIONS=1 is explicitly set. The
# print-dashboard nginx injects this token for the
# LAN dashboard automatically (compose passes it to both containers), so
# setting it does not break the dashboard buttons. Mirror the value in
# fulfillment's PRINTER_ORCHESTRATOR_API_TOKEN (apps/api/.env there).
# Generate with: openssl rand -hex 24
# ORCHESTRATOR_API_TOKEN=change-me
# Comma-separated origins allowed to call the API cross-origin. Empty (default)
# means same-origin only — correct for the nginx-proxied dashboard.
# CORS_ALLOW_ORIGINS=http://localhost:8090

# FAIL-CLOSED AUTH (canonical-dispatch cutover): with no ORCHESTRATOR_API_TOKEN
# set, every state-changing request is now REFUSED (503 AUTH_NOT_CONFIGURED).
# Running without auth requires this explicit opt-in — only on an isolated
# network segment:
# ALLOW_UNAUTHENTICATED_MUTATIONS=1

# Host-header allowlist (anti DNS-rebinding). Literal IPs, localhost and the
# compose service name always pass; every OTHER DNS name used to reach the
# dashboard/orchestrator must be listed here (comma-separated), e.g.:
# ALLOWED_HOSTS=farm.local,atelier.lan

# Which interface the dashboard (control-plane entry) is published on.
# Default 127.0.0.1 = host-only (fail-closed). LAN access is an explicit choice:
# DASHBOARD_BIND=0.0.0.0

# Bambu LAN MQTT uses a self-signed per-printer certificate, so connecting
# requires DISABLING TLS verification. That is now an explicit opt-in — either
# globally here, or per printer via "allowInsecureTls": true in printers.json.
# Only enable on an isolated/trusted VLAN:
# BAMBU_ALLOW_INSECURE_TLS=1

# ── Fulfillment warehouse integration (filament auto-deduction) ─────────────
# Base URL of the fulfillment API. Empty = the integration is disabled and the
# farm runs standalone. Example: http://192.168.0.139:3001
# FULFILLMENT_API_URL=
# Inter-service token for fulfillment's POST /api/inventory/filament/consume and
# POST /api/inventory/printer-filament/sync, sent as the `x-service-token`
# header on every call (including retry-queue redeliveries). Must be EXACTLY the
# same value as ATELIER_FULFILLMENT_TOKEN in fulfillment's env. Required once
# fulfillment's temporary ATELIER_FULFILLMENT_AUTH_OPTIONAL mode is off; without
# it every consume/sync is refused 401 (surfaced as an operator event).
# Generate with: openssl rand -hex 24. Never commit the real value.
# ATELIER_FULFILLMENT_TOKEN=
# Delay before re-posting a loaded-reel sync fulfillment answered
# `resolved: false` (the reel matched no warehouse stock yet). Default 5 min.
# FILAMENT_SYNC_RETRY_MS=300000
# Cap on the persistent retry queue of undelivered deductions; beyond it the
# oldest entry is dropped LOUDLY (operator event + dropped counter). Default 200.
# FILAMENT_RETRY_QUEUE_MAX=200
# How long a queued deduction keeps retrying before it is dropped (loudly).
# Default 7 days.
# FILAMENT_RETRY_MAX_AGE_DAYS=7

# Artifact retention: default age cutoff (days) used by the sweep endpoint
# POST /api/print/artifacts/retention/sweep when the request gives none.
# ARTIFACT_RETENTION_DAYS=30

# Graceful shutdown: how long to wait for in-flight analysis/slice jobs before
# closing the database (drain), and the hard cap before force-exit.
# SHUTDOWN_DRAIN_TIMEOUT_MS=15000
# SHUTDOWN_TIMEOUT_MS=25000

# Optional overrides:
# PRINTERS_CONFIG_PATH=/app/config/printers.json
# PRINTERS_CONFIG_JSON=[]           # inline config when no file is mounted
# PRINTER_POLL_INTERVAL_MS=10000
# Service process identity/listen settings (compose sets sensible values; only
# override for a non-standard deployment).
# NODE_ENV=production
# SERVICE_NAME=print-orchestrator
# SERVICE_VERSION=v0.1.0
# HOST=0.0.0.0
# PORT=3100
# LOG_LEVEL=info
# Fastify startup/onReady budget. The first real-device poll can legitimately
# exceed Fastify's 10 s default when a printer or camera is offline. Keep this
# below the orchestrator healthcheck start_period in compose.yml.
# STARTUP_TIMEOUT_MS=45000
# Durable state file (operator queue, event feed, today counters). Defaults to
# <cwd>/data/state.json; in Docker this is /app/data/state.json on the
# orchestrator-data volume. Override only if you move the data directory.
# STATE_FILE_PATH=/app/data/state.json
# SQLite database for the persistent print-queue model (tasks, assignments, the
# print-run chain, audit log). Defaults next to STATE_FILE_PATH
# (<state dir>/queue.db → /app/data/queue.db on the volume). Override only if you
# move the data directory. WAL is enabled, so *.db-wal / *.db-shm sit beside it.
# QUEUE_DB_PATH=/app/data/queue.db
# Saved camera snapshots: where the JPEG/PNG files live (metadata stays in the
# JSON state), how many to keep per printer, and how long to wait after
# switching a chamber light on before grabbing a night frame (ms).
# SNAPSHOTS_DIR=/app/data/snapshots
# SNAPSHOT_RETAIN_PER_PRINTER=30
# SNAPSHOT_LIGHT_SETTLE_MS=1200

# ── File upload & analysis (POST /api/print/artifacts) ──────────────────────
# Uploaded .stl/.3mf/.gcode files are stored content-addressed on disk
# (sha256/<prefix>/<hash>) under ARTIFACT_STORAGE_ROOT — never in SQLite — and
# analysed by a bounded in-process worker pool. All limits below are strictly
# positive; an invalid value fails startup with a clear message, an unset one
# uses the documented default shown.
# Root of the blob store; defaults next to STATE_FILE_PATH (<state dir>/artifacts
# → /app/data/artifacts on the volume). Temp uploads are staged in
# UPLOAD_TMP_DIR (default <root>/.tmp) and atomically moved in after hashing.
# ARTIFACT_STORAGE_ROOT=/app/data/artifacts
# UPLOAD_TMP_DIR=/app/data/artifacts/.tmp
# Maximum single-file size (bytes, default 200 MB). The print-dashboard nginx
# raises client_max_body_size to match; keep them in sync if you change this.
# MAX_UPLOAD_FILE_BYTES=209715200
# Advisory batch limits enforced by the dashboard (server accepts one file/req).
# MAX_UPLOAD_FILES=20
# MAX_UPLOAD_TOTAL_BYTES=524288000
# HARD server-side quotas (fail-closed): a new upload is refused (507) if it would
# push the artifact store past these, so a flood cannot fill the data volume.
# MAX_ARTIFACT_STORE_BYTES=21474836480        # 20 GB total stored (dedup-aware)
# MAX_ARTIFACT_COUNT=5000                      # total number of stored artifacts
# Free-disk reserve: refuse uploads (507) when the store's filesystem has less
# than this available, so state.json + SQLite on the same volume stay safe.
# UPLOAD_MIN_FREE_DISK_BYTES=536870912         # 512 MB
# Per-file analysis wall-clock budget (ms) and how many files analyse at once.
# The analyzer runs in a worker thread; the timeout TERMINATES it (real cancel).
# ANALYSIS_TIMEOUT_MS=30000
# ANALYSIS_CONCURRENCY=2
# Bound on the analysis backlog: an upload is refused (503) beyond this many
# queued/running analyses, instead of growing an unbounded queue.
# ANALYSIS_MAX_QUEUE=200
# 3MF is an untrusted ZIP: caps against zip bombs / oversized archives.
# UPLOAD_ZIP_MAX_ENTRIES=10000               # max entries in the archive
# UPLOAD_ZIP_MAX_ENTRY_BYTES=268435456       # 256 MB per decoded entry
# UPLOAD_ZIP_MAX_TOTAL_BYTES=536870912       # 512 MB total decoded across entries
# UPLOAD_ZIP_MAX_RATIO=200                   # max uncompressed/compressed ratio
# UPLOAD_XML_MAX_BYTES=67108864              # 64 MB per parsed 3MF XML document

# Local timezone used for NIGHT_PRINT_WINDOW and dashboard event times. Set this
# to the farm's real zone — the containers otherwise default to Europe/Kyiv (see
# compose.yml). With UTC the default 21:30–07:30 window is interpreted as UTC,
# so lights switch at the wrong local time.
# TZ=Europe/Kyiv
# Night-print window: night-plan duration checks and the dashboard's automatic
# dark/light theme follow it (delivered to the frontend in /api/dashboard as
# night.windowStart/windowEnd — the dashboard keeps no copy of the schedule,
# only a fallback equal to this default). NOT the light schedule any more —
# the chamber lights follow the LIGHT_* settings below.
# NIGHT_PRINT_WINDOW=21:30 – 07:30

# Manual scheduler (/api/print/scheduler). NIGHT_ETA_SAFETY_BUFFER is the fraction
# added to the source ETA for unattended-night recommendations while the farm has
# no historical P90 (0.2 → +20%); results stay flagged provisional. Telemetry older
# than SCHEDULER_TELEMETRY_STALE_MS is treated as stale → the task×printer verdict
# downgrades to "review" instead of "compatible".
# NIGHT_ETA_SAFETY_BUFFER=0.2
# SCHEDULER_TELEMETRY_STALE_MS=120000

# ── OrcaSlicer slicing runtime (optional) ───────────────────────────────────
# The orchestrator ships the vendored preset CATALOG (config/slicers/orca) but NOT
# an OrcaSlicer binary — OrcaSlicer is a desktop app and is not bundled in the
# image. With ORCA_SLICER_CMD unset the runtime is HONESTLY unavailable: every
# slice goes `blocked` with a clear reason (never a faked file/ETA), and the boot
# log + GET /api/print/slicing/runtime report say so. Monitoring, the queue and
# dispatch all work without it — configure this only if you want in-app slicing.
#
# Two supported shapes:
#   1. Container runtime, network-disabled (preferred — reproducible + isolated).
#      Requires giving the orchestrator container access to a container runtime
#      (mount the Docker socket in compose, or use rootless podman):
#        ORCA_SLICER_CMD=docker
#        ORCA_SLICER_BASE_ARGS=run --rm --network none <image> orca-slicer
#        ORCA_SLICER_NETWORK_ISOLATED=1
#   2. Host/mounted OrcaSlicer binary (mount it read-only via a compose volume):
#        ORCA_SLICER_CMD=/opt/orca/orca-slicer
#
# ORCA_SLICER_VERSION pins the release the vendored bundles were exported from
# (02.03.00.62 → 2.3.0); the runtime probe warns if the detected version differs,
# because resolved profile values would then not match what the CLI produces.
# ORCA_SLICER_CMD=
# ORCA_SLICER_BASE_ARGS=
# ORCA_SLICER_EXTRA_ARGS=
# ORCA_SLICER_VERSION=2.3.0
# ORCA_SLICER_NETWORK_ISOLATED=1
# Slice wall-clock budget (ms) and how many slices may run at once (heavy → 1).
# ORCA_SLICE_TIMEOUT_MS=600000
# ORCA_SLICE_CONCURRENCY=1
# Vendored preset catalog root and the per-slice temp workspace (both default
# to sensible in-image/data-volume locations; override only if relocated).
# ORCA_CATALOG_DIR=/app/config/slicers/orca
# ORCA_SLICE_TMP_DIR=/app/data/slice-tmp
# Host directory with the extracted OrcaSlicer AppImage (squashfs-root),
# mounted read-only at /opt/orca by the OPTIONAL compose override
# compose.orca.yml (docker compose -f compose.yml -f compose.orca.yml up).
# Required only when that override is used.
# ORCA_HOST_DIR=/home/<user>/opt/orca-2.3.0/squashfs-root
# Import the vendored catalog into the DB on first boot (idempotent). Missing
# system parents leave dependent presets quarantined — see
# config/slicers/orca/vendor/README.md to complete a working set.
# ORCA_AUTO_IMPORT=true

# Chamber-light schedule. `solar` (default) computes sunset/sunrise locally
# (suncalc, no external APIs) for the coordinates below and lights active
# (printing/paused) printers from sunset+LIGHT_ON_OFFSET_MINUTES until
# sunrise+LIGHT_OFF_OFFSET_MINUTES. An open dashboard tab additionally keeps
# supported printers lit for ~90 s per renewal (POST /api/monitoring/lease).
# `fixed` switches on a fixed window instead: LIGHT_FALLBACK_WINDOW when set,
# otherwise the legacy NIGHT_PRINT_WINDOW (the pre-solar behaviour).
# Invalid values never crash the service: it degrades to the fallback window
# and shows a warning on the dashboard.
# LIGHT_SCHEDULE_MODE=solar
# LIGHT_LATITUDE=50.45
# LIGHT_LONGITUDE=30.52
# LIGHT_ON_OFFSET_MINUTES=-30
# LIGHT_OFF_OFFSET_MINUTES=30
# LIGHT_ONLY_WHEN_ACTIVE=true
# Fallback/fixed window, format HH:MM-HH:MM (may cross midnight).
# LIGHT_FALLBACK_WINDOW=16:00-08:00

# ── go2rtc camera bridge (compose-level, no defaults in compose.yml) ─────────
# The Creality K2 camera source go2rtc bridges into WebRTC. Point it at the
# printer's local WebRTC endpoint; #format=creality enables the Creality
# signaling handshake. REQUIRED for the go2rtc service to stream the K2.
# K2_CAMERA_SOURCE=webrtc:http://<k2-printer-ip>:8000/call/webrtc_local#format=creality
# The ICE candidate the browser dials for WebRTC media: the HOST's LAN address
# and the published 8555 port (not the container IP). Update if the host IP
# changes. REQUIRED for live K2 video on LAN browsers.
# GO2RTC_WEBRTC_CANDIDATE=<host-lan-ip>:8555
